# Dispatch environment variables
# Copy to .env on the VPS and fill in real values. Never commit .env.

# Required in production — encrypts per-user Otus credentials in SQLite
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_KEY=

# Shared Otus admin portal account (both admins use these credentials at login)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Optional — signs session cookies (user + admin). Generate like CREDENTIALS_KEY.
# If unset, a random secret is generated once and stored in SQLite settings.
# SESSION_SECRET=

# Set when running behind Caddy/nginx HTTPS reverse proxy
TRUST_PROXY=1

# Optional
PORT=3000
NODE_ENV=production

# Used by deploy/vps-setup.sh only
# DISPATCH_DOMAIN=dispatch.example.com
# DISPATCH_REPO_URL=https://github.com/your-org/dispatch.git
